        current_pred_mask_path = os.path.join(predicted_mask_save_dir, f'pred_mask_{os.path.basename(os.path.splitext(current_image_path)[0])}.png')

        original_img = Image.open(current_image_path).convert('RGB')
        gt_mask = parse_xml_to_mask(current_xml_path, np.array(original_img).shape) * 255
        pred_mask = Image.open(current_pred_mask_path).convert('L')

        # サブプロットへの表示
        if num_samples_to_show == 1: # 1つのサンプルの場合、axesは1次元配列になる
            ax1, ax2, ax3 = axes[0], axes[1], axes[2]
        else: # 複数のサンプルの場合、axesは2次元配列になる
            ax1, ax2, ax3 = axes[i, 0], axes[i, 1], axes[i, 2]

        ax1.imshow(original_img)
        ax1.set_title(f'Sample {idx+1}: Original Image', fontsize=12)
        ax1.axis('off')

        ax2.imshow(gt_mask, cmap='gray')
        ax2.set_title(f'Sample {idx+1}: Ground Truth Mask', fontsize=12)
        ax2.axis('off')

        ax3.imshow(pred_mask, cmap='gray')
        ax3.set_title(f'Sample {idx+1}: Predicted Mask', fontsize=12)
        ax3.axis('off')

    plt.suptitle('Multi-Sample Segmentation Results', fontsize=20, y=1.02) # 全体のタイトル
    plt.tight_layout(rect=[0, 0.03, 1, 0.98]) # タイトルと被らないように調整
    plt.savefig(os.path.join(visualization_output_dir, 'multi_sample_segmentation_results.png'))
    plt.show()
    print(f"Multi-sample segmentation results saved to {os.path.join(visualization_output_dir, 'multi_sample_segmentation_results.png')}")


import torch
import torch.nn as nn
import torch.nn.functional as F
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader, random_split
from torchvision import transforms
from torchmetrics.classification import BinaryJaccardIndex
from PIL import Image, ImageDraw
import os
import matplotlib.pyplot as plt
import numpy as np
import xml.etree.ElementTree as ET
import cv2
# from skimage import measure # 既存コードにはあったが未使用なのでコメントアウト

# --- 1. ユーティリティ関数の定義 ---
def parse_xml_to_mask(xml_path, image_shape):
    """XMLファイルからマスク画像を生成する (連結成分解析なし)"""
    tree = ET.parse(xml_path)
    root = tree.getroot()
    mask = np.zeros(image_shape[:2], dtype=np.uint8)

    for region in root.iter('Region'):
        coords = []
        for vertex in region.iter('Vertex'):
            x = int(float(vertex.attrib['X']))
            y = int(float(vertex.attrib['Y']))
            coords.append((x, y))
        if coords:
            cv2.fillPoly(mask, [np.array(coords, dtype=np.int32)], color=1)
    return mask

class JointTransform:
    def __init__(self, image_size=(256, 256)):
        self.image_transform = transforms.Compose([
            transforms.Resize(image_size),
            transforms.ToTensor(),
            transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
        ])
        self.mask_transform = transforms.Compose([
            transforms.Resize(image_size, interpolation=Image.NEAREST),
            transforms.ToTensor()
        ])
        self.augment = transforms.Compose([
            transforms.RandomHorizontalFlip(),
            transforms.RandomVerticalFlip(),
            transforms.RandomRotation(degrees=10)
        ])

    def __call__(self, image, mask):
        image = Image.fromarray(image) # Convert numpy array to PIL Image
        mask = Image.fromarray(mask)

        # Apply augmentation to both image and mask
        # Note: Apply augmentation before resizing to maintain spatial relationship during rotation
        seed = torch.seed() # Get a random seed for consistent augmentation
        torch.manual_seed(seed)
        image = self.augment(image)
        torch.manual_seed(seed) # Use the same seed for mask
        mask = self.augment(mask)

        image = self.image_transform(image)
        mask = self.mask_transform(mask)
        mask = (mask > 0).float()  # 2値化（背景0、前景1）
        return image, mask

def generate_mask_from_xml_for_saving(xml_path, save_path, image_size=(1000, 1000)):
    """XMLファイルからマスク画像を生成し、PNGとして保存する関数 (元コードから)"""
    tree = ET.parse(xml_path)
    root = tree.getroot()

    mask = Image.new('L', image_size, 0)
    draw = ImageDraw.Draw(mask)

    for region in root.iter('Region'):
        points = []
        for point in region.iter('Vertex'):
            x = float(point.get('X'))
            y = float(point.get('Y'))
            points.append((x, y))
        if points:
            # fill=255 for white mask on black background
            draw.polygon(points, outline=255, fill=255)

    mask.save(save_path)

# --- 2. UNetモデル定義 ---
class UNet(nn.Module):
    def __init__(self):
        super(UNet, self).__init__()
        # Encoder
        self.encoder1 = nn.Conv2d(3, 64, kernel_size=3, padding=1)
        self.encoder2 = nn.Conv2d(64, 128, kernel_size=3, padding=1)
        self.encoder3 = nn.Conv2d(128, 256, kernel_size=3, padding=1)
        self.pool = nn.MaxPool2d(2)

        # Decoder (with skip connections implicitly handled by upsampling before concatenation in UNet architecture,
        # but in this simplified UNet, it's a direct upsample and conv)
        self.decoder1 = nn.Conv2d(256, 128, kernel_size=3, padding=1)
        self.decoder2 = nn.Conv2d(128, 64, kernel_size=3, padding=1)
        self.decoder3 = nn.Conv2d(64, 1, kernel_size=3, padding=1) # Output 1 channel for binary mask

        # Upsampling
        self.upconv1 = nn.ConvTranspose2d(256, 256, kernel_size=2, stride=2)
        self.upconv2 = nn.ConvTranspose2d(128, 128, kernel_size=2, stride=2)
        self.upconv3 = nn.ConvTranspose2d(64, 64, kernel_size=2, stride=2)

    def forward(self, x):
        # Encoder path
        e1 = F.relu(self.encoder1(x)) # (Batch, 64, H, W)
        e2 = F.relu(self.encoder2(self.pool(e1))) # (Batch, 128, H/2, W/2)
        e3 = F.relu(self.encoder3(self.pool(e2))) # (Batch, 256, H/4, W/4)

        # Decoder path
        d1 = F.relu(self.decoder1(self.upconv1(e3))) # (Batch, 128, H/2, W/2)
        d2 = F.relu(self.decoder2(self.upconv2(d1))) # (Batch, 64, H, W)
        d3 = self.decoder3(self.upconv3(d2)) # (Batch, 1, 2*H, 2*W)

        d3_resized = F.interpolate(d3, size=(256, 256), mode='bilinear', align_corners=False)
        return d3_resized

# --- 3. データセット定義 ---
class SegmentationDataset(Dataset):
    def __init__(self, image_paths, xml_paths, transform=None):
        self.image_paths = image_paths
        self.xml_paths = xml_paths # Store XML paths to parse masks on-the-fly
        self.transform = transform

    def __len__(self):
        return len(self.image_paths)

    def __getitem__(self, idx):
        image = cv2.imread(self.image_paths[idx])
        image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB) # OpenCV reads in BGR format

        # Parse mask directly from XML for ground truth (as provided in the user's code for Dataset)
        mask = parse_xml_to_mask(self.xml_paths[idx], image.shape)

        if self.transform:
            image, mask = self.transform(image, mask)

        return image, mask

# --- 4. データパス設定 ---
image_dir = '/kaggle/input/monuseg-training/MoNuSeg_Training/Images'
xml_dir = '/kaggle/input/monuseg-training/MoNuSeg_Training/Annotations'
mask_output_dir = '/kaggle/working/Output_Masks' # Directory for masks generated for saving (not for dataset loading if parsing from xml)
predicted_mask_save_dir = '/kaggle/working/Predicted_Masks'
visualization_output_dir = '/kaggle/working/Visualization_Outputs' # 新規追加：可視化結果の保存先

# XMLからマスク画像を生成 (DatasetがXMLを直接読み込むので、これはファイル保存用として機能。資料化で使う)
os.makedirs(mask_output_dir, exist_ok=True)
if not os.listdir(mask_output_dir): # Only generate if directory is empty
    print(f"Generating ground truth mask images and saving to {mask_output_dir}...")
    for xml_file in os.listdir(xml_dir):
        if xml_file.endswith('.xml'):
            image_name = os.path.splitext(xml_file)[0] + '.png'
            corresponding_image_path = os.path.join(image_dir, os.path.splitext(xml_file)[0] + '.tif')
            if os.path.exists(corresponding_image_path):
                original_image_for_size = Image.open(corresponding_image_path)
                img_width, img_height = original_image_for_size.size
                generate_mask_from_xml_for_saving(os.path.join(xml_dir, xml_file),
                                                  os.path.join(mask_output_dir, image_name),
                                                  image_size=(img_width, img_height))
    print("Ground truth mask image generation complete.")
else:
    print(f"Ground truth mask images already exist in {mask_output_dir}. Skipping generation.")

image_paths = sorted([os.path.join(image_dir, fname) for fname in os.listdir(image_dir) if fname.endswith('.tif')])
xml_paths = sorted([os.path.join(xml_dir, fname) for fname in os.listdir(xml_dir) if fname.endswith('.xml')])
# The mask_file_paths here is for the saved mask images, not directly used by the dataset, which parses from XML.
mask_file_paths = sorted([os.path.join(mask_output_dir, fname) for fname in os.listdir(mask_output_dir) if fname.endswith('.png')])


# --- 5. データ変換設定 ---
transform = JointTransform(image_size=(256, 256)) # Model input size

# --- 6. データローダー作成 ---
dataset = SegmentationDataset(image_paths, xml_paths, transform=transform)

# データセットを訓練セットと検証セットに分割
train_size = int(0.8 * len(dataset))
val_size = len(dataset) - train_size
train_dataset, val_dataset = random_split(dataset, [train_size, val_size])

train_dataloader = DataLoader(train_dataset, batch_size=4, shuffle=True, num_workers=2)
val_dataloader = DataLoader(val_dataset, batch_size=4, shuffle=False, num_workers=2)

# --- 7. モデル、損失関数、最適化手法の設定 ---
device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
model = UNet().to(device)
criterion = nn.BCEWithLogitsLoss()
optimizer = optim.Adam(model.parameters(), lr=1e-3)
scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, 'min', patience=5, factor=0.5) # Learning rate scheduler

# --- 8. 学習ループ ---
num_epochs = 80 # <-- ここでエポック数を増やします。資料用にはこのくらいが妥当でしょう
print(f"\nStarting training for {num_epochs} epochs...")
loss_history = {'train': [], 'val': []}
final_val_iou = 0.0 # 最終IoUを保存するための変数

for epoch in range(num_epochs):
    print(f'Epoch [{epoch+1}/{num_epochs}]')

    # Training
    model.train()
    total_loss = 0
    for images, masks in train_dataloader:
        images, masks = images.to(device), masks.to(device)

        optimizer.zero_grad()
        outputs = model(images)
        loss = criterion(outputs, masks)
        loss.backward()
        optimizer.step()
        total_loss += loss.item()

    avg_train_loss = total_loss / len(train_dataloader)
    loss_history['train'].append(avg_train_loss)
    print(f'  Train Loss: {avg_train_loss:.4f}')

    # Validation
    model.eval()
    total_val_loss = 0
    iou = BinaryJaccardIndex().to(device) # Reset IoU metric for each epoch

    with torch.no_grad():
        for images, masks in val_dataloader:
            images, masks = images.to(device), masks.to(device)

            outputs = model(images)
            loss = criterion(outputs, masks)
            total_val_loss += loss.item()

            preds = torch.sigmoid(outputs)
            preds = (preds > 0.5).float()
            iou.update(preds, masks.int())

    avg_val_loss = total_val_loss / len(val_dataloader)
    loss_history['val'].append(avg_val_loss)
    mean_iou = iou.compute()
    print(f'  Val Loss: {avg_val_loss:.4f}, Val IoU: {mean_iou:.4f}')
    final_val_iou = mean_iou.item() # 最終IoUを更新

    scheduler.step(avg_val_loss) # Update learning rate scheduler
print("Training complete.")

# --- 9. 学習結果サマリーの出力 (新規追加) ---
print("\n--- Training Summary ---")
print(f"Total Epochs: {num_epochs}")
print(f"Final Train Loss: {loss_history['train'][-1]:.4f}")
print(f"Final Val Loss: {loss_history['val'][-1]:.4f}")
print(f"Final Val IoU: {final_val_iou:.4f}")
print("------------------------")


# --- 10. 学習曲線の表示と保存 ---
os.makedirs(visualization_output_dir, exist_ok=True)
