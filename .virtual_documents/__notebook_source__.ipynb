model.eval()
with torch.no_grad():
    for i, image_path in enumerate(image_paths):
        original_image_pil = Image.open(image_path).convert('RGB')
        image_tensor = transform.image_transform(original_image_pil).unsqueeze(0).to(device)

        output = model(image_tensor)
        pred_mask_tensor = torch.sigmoid(output).squeeze().cpu()
        pred_mask_np = (pred_mask_tensor > 0.5).numpy().astype(np.uint8) * 255

        original_width, original_height = original_image_pil.size
        pred_mask_resized = cv2.resize(pred_mask_np, (original_width, original_height), interpolation=cv2.INTER_NEAREST)

        save_path = os.path.join(predicted_mask_save_dir, f'pred_mask_{os.path.basename(os.path.splitext(image_path)[0])}.png')
